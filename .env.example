# Copy to .env and fill in real values. Never commit the filled-in .env.
#
#   cp .env.example .env

# ---- Server ----------------------------------------------------------------
PORT=5000
NODE_ENV=development

# Origin allowed by CORS. Must match the frontend dev server.
CLIENT_ORIGIN=http://localhost:5173

# ---- Database --------------------------------------------------------------
# MongoDB connection string (Atlas or local).
#   Atlas: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/
#   Local: mongodb://127.0.0.1:27017/
MONGODB_URI=

# Database name. Defaults to "buddyscript" if left blank.
MONGODB_DB=buddyscript

# ---- Auth ------------------------------------------------------------------
# Two DIFFERENT random secrets. Generate each with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=
JWT_REFRESH_SECRET=

JWT_EXPIRY=24h
JWT_REFRESH_EXPIRY=30d

# ---- Uploads ---------------------------------------------------------------
# Where post images are written. Defaults to server/uploads.
# In production point this at a MOUNTED PERSISTENT DISK — a plain container
# filesystem is wiped on every redeploy, taking every uploaded image with it.
# UPLOAD_DIR=/var/data/uploads
