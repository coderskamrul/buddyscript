# Copy to .env and fill in real values. Never commit the filled-in .env.
#
#   cp .env.example .env

# ---- Server ----------------------------------------------------------------
PORT=5000
NODE_ENV=development

# Origin allowed by CORS. Must match the frontend dev server.
CLIENT_ORIGIN=http://localhost:5173

# ---- Database --------------------------------------------------------------
# MongoDB connection string (Atlas or local).
#   Atlas: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/
#   Local: mongodb://127.0.0.1:27017/
MONGODB_URI=

# Database name. Defaults to "buddyscript" if left blank.
MONGODB_DB=buddyscript

# ---- Redis -----------------------------------------------------------------
# Powers the cache, the rate limiter, the materialized feed timelines, and the
# BullMQ job queues. See ARCHITECTURE.md.
#
#   Local:  redis://127.0.0.1:6379           (brew install redis && redis-server)
#   Cloud:  rediss://:<password>@<host>:<port>   (Upstash, Redis Cloud, ElastiCache)
#
# REQUIRED IN PRODUCTION — the server refuses to boot without it, deliberately:
# without Redis the rate limiter and cache fall back to per-process state, which
# is silently WRONG the moment there is more than one instance behind a load
# balancer.
#
# OPTIONAL IN DEVELOPMENT. Leave it blank and the app boots in DEGRADED MODE
# (cache off, rate limits in-memory, background jobs dropped) and says so loudly
# at startup. Fine for working on the UI; not fine for anything else.
REDIS_URL=redis://127.0.0.1:6379

# Namespaces every key, so one Redis can host several environments without them
# reading each other's cache. Defaults to bs:<NODE_ENV>:
# REDIS_KEY_PREFIX=bs:development:

# ---- Feed tuning -----------------------------------------------------------
# THE fan-out threshold. An author with FEWER followers than this has each post
# PUSHED into every follower's timeline on write (fan-out on write). An author
# with MORE has their posts PULLED at read time instead (fan-out on read), and
# no timeline entry is ever written for them.
#
# This is what stops a 1M-follower post from becoming 1M writes. See
# ARCHITECTURE.md §5.
# FEED_CELEBRITY_THRESHOLD=10000

# How many followers one fan-out batch job handles. Keeps any single job short
# (seconds, not minutes) so a worker restart re-does very little.
# FEED_FANOUT_BATCH_SIZE=1000

# A materialized timeline is a cache, not an archive. Beyond this, reads fall
# back to Mongo.
# FEED_TIMELINE_MAX_LENGTH=800

# ---- Cache TTLs (seconds) --------------------------------------------------
# The head feed page is where new posts land, so it expires fast. Pages BELOW the
# head are stable windows under keyset pagination — no future post can enter them
# — so they cache far longer. See ARCHITECTURE.md §6.
# CACHE_FEED_HEAD_TTL=20
# CACHE_FEED_PAGE_TTL=300
# CACHE_POST_TTL=600
# CACHE_FOLLOWING_TTL=300

# ---- Rate limiting ---------------------------------------------------------
# Counters live in Redis, so the limit is a property of the SYSTEM rather than of
# whichever container the load balancer happened to pick.
# RATE_LIMIT_GLOBAL=600     # per minute
# RATE_LIMIT_WRITE=60       # per minute
# RATE_LIMIT_AUTH=20        # per 15 minutes, failures only

# ---- Logging ---------------------------------------------------------------
# LOG_LEVEL=debug           # fatal | error | warn | info | debug | trace
# LOG_PRETTY=true           # human-readable locally; leave false in prod (JSON)

# ---- Auth ------------------------------------------------------------------
# Two DIFFERENT random secrets. Generate each with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=
JWT_REFRESH_SECRET=

JWT_EXPIRY=24h
JWT_REFRESH_EXPIRY=30d

# ---- Uploads (Cloudinary) --------------------------------------------------
# Post images are uploaded to Cloudinary and served from its CDN. The database
# stores only the file name; the folder and cloud name below are what it is
# resolved against. Find all three at cloudinary.com > Dashboard.
#
# The server will refuse to boot without them, which is deliberate: the
# alternative is writing uploads to a container filesystem that is wiped on the
# next redeploy, and discovering it only once the images are already gone.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=buddyscript/posts

# The browser builds its own image URLs (so it can request the width it actually
# needs), so it needs the same two non-secret values. Only VITE_-prefixed keys
# reach the bundle — which is exactly why the API secret above has no VITE_ twin.
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_FOLDER=buddyscript/posts

# Legacy only: where post images used to be written, before Cloudinary. Nothing
# writes here now — it is still served so that pre-existing posts (and the one
# the seed script creates) don't render as broken images.
# UPLOAD_DIR=/var/data/uploads
