{
  "name": "buddyscript-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "BuddyScript API — Express + MongoDB backend for the social feed",
  "main": "src/server.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",

    "// worker": "The background job consumers. A SEPARATE process from the API — see src/worker.js. Run at least one alongside `start` in production; scale it independently of the web tier.",
    "worker": "node src/worker.js",
    "worker:dev": "nodemon src/worker.js",

    "seed": "node src/scripts/seed.js",
    "indexes": "node src/scripts/syncIndexes.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.80.2",
    "cloudinary": "^2.10.0",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.6.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "pino": "^9.14.0",
    "pino-http": "^10.5.0",
    "rate-limit-redis": "^4.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "nodemon": "^3.1.4",
    "pino-pretty": "^13.1.3"
  }
}
